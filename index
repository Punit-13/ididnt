<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>I Didn't</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
}

body{
    background:#111;
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    overflow:hidden;
}

.card{
    width:380px;
    background:#1c1c1e;
    border-radius:25px;
    padding:40px;
    text-align:center;
    box-shadow:0 20px 50px rgba(0,0,0,.45);
    animation:fade .6s ease;
}

@keyframes fade{
from{opacity:0;transform:translateY(20px);}
to{opacity:1;transform:translateY(0);}
}

h1{
    font-size:42px;
    margin-bottom:10px;
}

.subtitle{
    color:#9a9a9a;
    margin-bottom:35px;
}

.question{
    font-size:22px;
    margin-bottom:30px;
    line-height:1.4;
}

button{
    width:140px;
    padding:15px;
    margin:8px;
    border:none;
    border-radius:14px;
    font-size:17px;
    cursor:pointer;
    transition:.25s;
}

button:hover{
    transform:scale(1.05);
}

.yes{
    background:#ff453a;
    color:white;
}

.no{
    background:#30d158;
    color:white;
}

#result{
    margin-top:35px;
    font-size:21px;
    line-height:1.6;
}
</style>

</head>

<body>

<div class="card">

<h1>I Didn't</h1>

<p class="subtitle">A very important question.</p>

<div class="question">
Anya,<br><br>
Did you lie today?
</div>

<button class="yes" onclick="lied()">Yes</button>

<button class="no" onclick="truth()">No</button>

<div id="result"></div>

</div>

<script>

function lied(){
document.getElementById("result").innerHTML=
"🚫 <b>No coffee for you.</b><br><br>Honesty comes before caffeine.";
}

function truth(){
document.getElementById("result").innerHTML=
"☕ <b>Here's your coffee!</b><br><br>You work too much—you've earned it. 🚀";
}

</script>

</body>
</html>